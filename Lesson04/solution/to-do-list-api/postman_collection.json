    "item": [
        {
            "name": "Get All Tasks",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Test 1: Status code is 200",
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "// Test 2: Response time is less than 200ms",
                            "pm.test(\"Response time is less than 200ms\", function () {",
                            "    pm.expect(pm.response.responseTime).to.be.below(200);",
                            "});",
                            "",
                            "// Test 3: Response has correct structure",
                            "pm.test(\"Response has data and metadata objects\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData).to.have.property('data');",
                            "    pm.expect(jsonData).to.have.property('metadata');",
                            "});",
                            "",
                            "// Test 4: Data has tasks array and count",
                            "pm.test(\"Data has tasks array and count\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.data).to.have.property('tasks');",
                            "    pm.expect(jsonData.data).to.have.property('count');",
                            "    pm.expect(jsonData.data.tasks).to.be.an('array');",
                            "});",
                            "",
                            "// Test 5: Metadata has links",
                            "pm.test(\"Metadata has links\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.metadata).to.have.property('links');",
                            "    pm.expect(jsonData.metadata.links).to.have.property('self');",
                            "    pm.expect(jsonData.metadata.links).to.have.property('create');",
                            "});",
                            "",
                            "// Test 6: Each task has links",
                            "pm.test(\"Each task has links\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    if (jsonData.data.tasks.length > 0) {",
                            "        jsonData.data.tasks.forEach(function(task) {",
                            "            pm.expect(task).to.have.property('links');",
                            "            pm.expect(task.links).to.have.property('self');",
                            "            pm.expect(task.links).to.have.property('update');",
                            "            pm.expect(task.links).to.have.property('delete');",
                            "        });",
                            "    }",
                            "});",
                            "",
                            "// Test 7: Content-Type is application/json",
                            "pm.test(\"Content-Type is application/json\", function () {",
                            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
